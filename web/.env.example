# Public — baked into client bundle (Supabase anon key is designed to be public; protect data with RLS)
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Legacy names for react-native-dotenv (@env). Same values; keep both for compatibility.
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only — used by Vercel serverless function at /api/gemini. NEVER prefix with EXPO_PUBLIC_.
GEMINI_API_KEY=your_gemini_api_key

# Optional: only needed for native builds. Web on Vercel uses same-origin.
# EXPO_PUBLIC_API_BASE=https://your-app.vercel.app
