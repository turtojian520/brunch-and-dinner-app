# Public — baked into client bundle (Supabase anon key is designed to be public; protect data with RLS)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only — used by Vercel serverless function at /api/gemini. NEVER prefix with VITE_.
GEMINI_API_KEY=your_gemini_api_key

# --- Resend API key for sending OTP emails (server-only, used by /api/auth/send-otp.js) ---
# Get your API key at https://resend.com/api-keys — starts with "re_"
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=WhatToEat <noreply@yourdomain.com>

# --- Supabase service_role key (server-only, used by /api/auth/verify-otp.js) ---
# Find this in Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: only needed for native builds. Web on Vercel uses same-origin.
# VITE_API_BASE=https://whattoreat.space
