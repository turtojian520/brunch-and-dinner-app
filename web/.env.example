# Public — baked into client bundle (Supabase anon key is designed to be public; protect data with RLS)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only — used by Vercel serverless function at /api/gemini. NEVER prefix with VITE_.
GEMINI_API_KEY=your_gemini_api_key

# Optional: only needed for native builds. Web on Vercel uses same-origin.
# VITE_API_BASE=https://whattoreat.space
